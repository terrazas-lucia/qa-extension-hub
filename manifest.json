{
  "manifest_version": 3,
  "name": "QA FORD Extension Hub",
  "version": "1.7",
  "description": "A centralized dashboard of all the extensions available to use within the FORD QA team.",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "contextMenus",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "launcher_popup.html",
    "default_icon": {
      "16": "icons/test1_16.png",
      "48": "icons/test1_48.png",
      "128": "icons/test1_128.png"
    }
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "icons": {
    "16": "icons/test1_16.png",
    "48": "icons/test1_48.png",
    "128": "icons/test1_128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}